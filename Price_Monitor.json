    {
      "parameters": {
        "language": "pythonNative",
        "pythonCode": "# 1. سحب السعر الحالي من الـ HTTP Request اللي قبله\n# افتراضاً أن الـ API بيرجع السعر في متغير اسمه price\n\ncurrent_price = _items[0][\"json\"][\"price_at_time\"]\n\n# 2. تحديد السعر المستهدف اللي نفسك تشتري عنده (مثال)\ntarget_price = 5690 \n\nlast_price = _items[0][\"json\"][\"last_price\"]\n\nis_below_target = current_price <= target_price\n\n# 3. حساب نسبة الهبوط\nprice_drop_percentage = 0\nif last_price > current_price:\n    price_drop_percentage = ((last_price - current_price) / last_price) * 100\n\nis_sharp_drop = price_drop_percentage >= 2.0\nshould_trigger = is_below_target or is_sharp_drop\n\nreturn {\n    \"current_price\": current_price,\n    \"last_price\": last_price,\n    \"target_price\": target_price,\n    \"is_below_target\": is_below_target,\n    \"is_sharp_drop\": is_sharp_drop,\n    \"price_drop_percentage\": round(price_drop_percentage, 2),\n    \"should_trigger\": should_trigger\n}"
      },
      "type": "n8n-nodes-base.code",
